# Free/local OCR is enabled by default.
# Optional high-accuracy handwriting OCR:
# 1. Install: pip install -r requirements-vision.txt
# 2. Set ENABLE_TROCR=true
# 3. First run downloads the Hugging Face model unless it is already cached.
ENABLE_TROCR=false
TROCR_MODEL=microsoft/trocr-base-handwritten
TROCR_DEVICE=auto
TROCR_MAX_LINES=80

# Optional external OCR fallback. Leave empty for no paid/external API.
OCR_SPACE_API_KEY=
