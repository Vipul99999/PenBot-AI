NODE_ENV=production
PORT=4000
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/penbot
JWT_SECRET=replace_with_long_random_secret
AI_SERVICE_URL=https://your-ai-service.example.com
CLIENT_URL=https://your-frontend.example.com
CLIENT_URLS=https://your-frontend.example.com,https://www.your-frontend.example.com
COOKIE_SECURE=true
TRUST_PROXY=1
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=PenBot AI <your_email@gmail.com>
ADMIN_EMAILS=admin@example.com
MAX_UPLOAD_MB=20
MAX_USER_STORAGE_MB=250
